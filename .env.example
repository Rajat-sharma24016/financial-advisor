PORT=8080

# SEC asks every automated client to identify itself.
# Use your real app/contact. Example: FilingAdvisorAgent/1.0 admin@example.com
SEC_USER_AGENT=FilingAdvisorAgent/1.0 your-email@example.com

# Optional. Without this, the app uses a deterministic rules-based analyst.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
